{
  "name": "choropleth-map",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "전국 읍면동 코로플레스 맵 웹서비스",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "cross-env GH_PAGES=1 vite build && gh-pages -d dist",
    "build:single": "cross-env SINGLE=1 vite build",
    "build:all": "npm run build && npm run build:embedded && npm run build:gh",
    "build:embedded": "cross-env SINGLE=1 vite build && node scripts/embed-data.mjs",
    "build:gh": "cross-env GH_PAGES=1 vite build"
  },
  "dependencies": {
    "chroma-js": "^2.4.2",
    "html2canvas": "^1.4.1",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "simple-statistics": "^7.8.3",
    "topojson-client": "^3.1.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "gh-pages": "^6.1.1",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.3",
    "vite-plugin-singlefile": "^2.3.3"
  }
}